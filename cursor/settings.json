{
  "cursor.composer.shouldAllowCustomModes": true,
  "cursor.composer.shouldAutoAcceptDiffs": false,
  "diffEditor.ignoreTrimWhitespace": true,
  "editor.autoClosingBrackets": "never",
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "editor.colorDecorators": true,
  "editor.cursorSmoothCaretAnimation": "explicit",
  "editor.cursorStyle": "block",
  "editor.cursorSurroundingLines": 8,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "Simono, 'Berkeley Mono', 'IBM Plex Mono', 'Geist Mono', monospace",
  "editor.fontSize": 14,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.guides.bracketPairs": "active",
  "editor.lineHeight": 1.55,
  "editor.linkedEditing": true,
  "editor.minimap.autohide": true,
  "editor.minimap.enabled": false,
  "explorer.compactFolders": false,
  "git.allowNoVerifyCommit": true,
  "git.autofetch": true,
  "git.branchPrefix": "simone/",
  "git.branchProtection": [
    "main",
    "master",
    "prod",
    "production"
  ],
  "git.branchRandomName.enable": true,
  "git.confirmSync": true,
  "git.enableSmartCommit": true,
  "githubPullRequests.fileListLayout": "tree",
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.currentLine.pullRequests.enabled": false,
  "gitlens.currentLine.scrollable": false,
  "gitlens.fileAnnotations.command": "blame",
  "html.autoClosingTags": false,
  "javascript.autoClosingTags": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.trustedDomains": {
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://turborepo.dev/schema.json": true,
    "https://www.schemastore.org/": true,
    "https://opencode.ai": true,
    "https://models.dev": true
  },
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": false,
  "todohighlight.defaultStyle": {
    "borderRadius": "3px"
  },
  "todohighlight.keywords": [
    "FIXME:",
    "TODO:",
    {
      "backgroundColor": "rgba(255, 255, 255, 0.4)",
      "color": "black",
      "text": "NOTE:"
    }
  ],
  "typescript.autoClosingTags": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vim.smartRelativeLine": true,
  "window.customTitleBarVisibility": "never",
  "window.nativeTabs": true,
  "window.title": "${rootName}${separator}${profileName}",
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "Monokai Pro (Filter Spectrum)",
  "workbench.editorAssociations": {
    "*.svg": "default"
  },
  "workbench.iconTheme": "minimal-icons",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "readme",
  "workbench.tips.enabled": false,
  "workbench.tree.indent": 13
}