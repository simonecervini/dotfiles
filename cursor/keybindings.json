// Place your key bindings in this file to override the defaultsauto[]
[
  // alt+j (highlight previous word)
  {
    "key": "alt+j",
    "command": "editor.action.wordHighlight.prev",
    "when": "editorTextFocus && hasWordHighlights"
  },
  {
    "key": "shift+f7",
    "command": "-editor.action.wordHighlight.prev",
    "when": "editorTextFocus && hasWordHighlights"
  },
  // alt+k (highlight next word)
  {
    "key": "alt+k",
    "command": "editor.action.wordHighlight.next",
    "when": "editorTextFocus && hasWordHighlights"
  },
  {
    "key": "f7",
    "command": "-editor.action.wordHighlight.next",
    "when": "editorTextFocus && hasWordHighlights"
  },
  // ctrl+f (go to references)
  {
    "key": "ctrl+f",
    "command": "-cursorRight",
    "when": "textInputFocus"
  },
  {
    "key": "ctrl+f",
    "command": "editor.action.goToReferences",
    "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
  },
  {
    "key": "shift+f12",
    "command": "-editor.action.goToReferences",
    "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
  },
  // alt+cmd+s (toggle unified sidebar)
  {
    "key": "alt+cmd+s",
    "command": "-workbench.action.toggleUnifiedSidebar",
    "when": "cursor.agentIdeUnification.enabled && !isAuxiliaryWindowFocusedContext"
  },
  // ctrl+cmd+enter (git wip)
  {
    "key": "ctrl+cmd+enter",
    "command": "workbench.action.tasks.runTask",
    "args": "git-wip"
  },
  // ctrl+cmd+alt+enter (git wip without skip ci)
  {
    "key": "ctrl+cmd+alt+enter",
    "command": "workbench.action.tasks.runTask",
    "args": "git-wip-no-skip-ci"
  },
  // cmd+t (open new native tab)
  {
    "key": "cmd+t",
    "command": "workbench.action.newWindowTab"
  }
]
